# user creation/teardown). Copy the "service_role" / "Secret" key printed by
# `npx supabase start` (or `npx supabase status`) into your local .env.
SUPABASE_SERVICE_ROLE_KEY=###
OPENROUTER_API_KEY=###
OPENROUTER_MOCK=true